{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DDEV GUI",
  "version": "0.1.0",
  "identifier": "io.ddevgui.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DDEV GUI",
        "width": 880,
        "height": 640,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Manage DDEV projects from a Linux desktop GUI and tray",
    "longDescription": "DDEV GUI is a lightweight desktop dashboard and status-bar indicator for managing local DDEV projects: see live status, start/stop/restart, open sites and Mailpit, and get desktop notifications.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {}
}
